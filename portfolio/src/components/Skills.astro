---
const skillCategories = [
  {
    title: "Cloud & Storage",
    color: "accent-green",
    skills: ["AWS", "GCP", "Azure", "Ceph", "OpenStack", "Swift"],
  },
  {
    title: "Programming Languages",
    color: "accent-blue",
    skills: ["Python", "Golang", "Bash", "Java"],
  },
  {
    title: "Observability",
    color: "accent-cyan",
    skills: ["Grafana", "Perses", "Prometheus", "Splunk", "Dynatrace"],
  },
  {
    title: "Containerization",
    color: "accent-red",
    skills: ["Docker", "Kubernetes (EKS, AKS)", "Rook-Ceph"],
  },
  {
    title: "Infrastructure as Code",
    color: "accent-yellow",
    skills: ["Terraform", "AWS CloudFormation"],
  },
  {
    title: "CI/CD",
    color: "accent-purple",
    skills: ["Jenkins", "AWS CodePipeline", "GitHub Actions"],
  },
  {
    title: "Databases",
    color: "accent-green",
    skills: ["PostgreSQL", "MySQL", "DynamoDB", "AWS RDS"],
  },
  {
    title: "Frameworks",
    color: "accent-blue",
    skills: ["Flask", "Spring Boot", "Spring Batch"],
  },
];
---

<section id="skills" class="py-24">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="mb-2 font-mono text-sm text-accent-green">$ neofetch --skills</h2>
    <h3 class="mb-12 text-3xl font-bold text-white">Skills</h3>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {skillCategories.map((cat) => (
        <div class="rounded-lg border border-panel-border bg-panel-light p-5">
          <h4 class={`mb-3 font-mono text-xs font-semibold text-${cat.color}`}>
            {cat.title}
          </h4>
          <div class="flex flex-wrap gap-2">
            {cat.skills.map((skill) => (
              <span class="rounded-full border border-panel-border bg-panel px-2.5 py-1 text-xs text-gray-300">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
