<section id="about" class="py-24">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Terminal-style hero -->
    <div class="mb-12 rounded-lg border border-panel-border bg-panel-light p-8">
      <div class="mb-4 flex items-center gap-2">
        <span class="h-3 w-3 rounded-full bg-accent-red"></span>
        <span class="h-3 w-3 rounded-full bg-accent-yellow"></span>
        <span class="h-3 w-3 rounded-full bg-accent-green"></span>
        <span class="ml-4 font-mono text-xs text-gray-500">about.sh</span>
      </div>
      <h1 class="mb-2 text-4xl font-bold text-white md:text-5xl">
        Venkata Avinash <span class="text-accent-green">Addagada</span>
      </h1>
      <p class="mb-6 font-mono text-lg text-accent-cyan">
        Cloud Native Developer &amp; Site Reliability Engineer
      </p>
      <p class="max-w-3xl leading-relaxed text-gray-400">
        Accomplished Cloud Native Developer and Site Reliability Engineer with a comprehensive skill set
        encompassing AWS, GCP, Azure, and Ceph/OpenStack storage automation. Experienced in automating
        infrastructure provisioning and managing Kubernetes clusters, Ceph clusters, and Python APIs,
        leveraging Jenkins, Terraform, and Golang for high-scale environments. Expertise in monitoring
        and optimizing system reliability using Splunk, Dynatrace, Grafana, and Perses, while implementing
        SRE metrics (SLIs, SLOs, SLAs) to ensure performance and cost efficiency.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <span class="rounded-full border border-panel-border bg-panel px-3 py-1 font-mono text-xs text-accent-green">AWS</span>
        <span class="rounded-full border border-panel-border bg-panel px-3 py-1 font-mono text-xs text-accent-blue">GCP</span>
        <span class="rounded-full border border-panel-border bg-panel px-3 py-1 font-mono text-xs text-accent-cyan">Azure</span>
        <span class="rounded-full border border-panel-border bg-panel px-3 py-1 font-mono text-xs text-accent-purple">Kubernetes</span>
        <span class="rounded-full border border-panel-border bg-panel px-3 py-1 font-mono text-xs text-accent-yellow">Terraform</span>
        <span class="rounded-full border border-panel-border bg-panel px-3 py-1 font-mono text-xs text-accent-red">Python</span>
        <span class="rounded-full border border-panel-border bg-panel px-3 py-1 font-mono text-xs text-accent-green">Golang</span>
        <span class="rounded-full border border-panel-border bg-panel px-3 py-1 font-mono text-xs text-accent-blue">Ceph</span>
        <span class="rounded-full border border-panel-border bg-panel px-3 py-1 font-mono text-xs text-accent-cyan">OpenStack</span>
        <span class="rounded-full border border-panel-border bg-panel px-3 py-1 font-mono text-xs text-accent-purple">Rook-Ceph</span>
        <span class="rounded-full border border-panel-border bg-panel px-3 py-1 font-mono text-xs text-accent-yellow">Docker</span>
      </div>
    </div>
    <!-- Metrics row -->
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
      <div class="rounded-lg border border-panel-border bg-panel-light p-4 text-center">
        <p class="text-2xl font-bold text-accent-green">5</p>
        <p class="text-xs text-gray-500">Cloud Certifications</p>
      </div>
      <div class="rounded-lg border border-panel-border bg-panel-light p-4 text-center">
        <p class="text-2xl font-bold text-accent-blue">7+</p>
        <p class="text-xs text-gray-500">Years Experience</p>
      </div>
      <div class="rounded-lg border border-panel-border bg-panel-light p-4 text-center">
        <p class="text-2xl font-bold text-accent-purple">Multi-Cloud</p>
        <p class="text-xs text-gray-500">AWS · GCP · Azure</p>
      </div>
      <div class="rounded-lg border border-panel-border bg-panel-light p-4 text-center">
        <p class="text-2xl font-bold text-accent-yellow">MS CS</p>
        <p class="text-xs text-gray-500">Texas Tech University</p>
      </div>
    </div>
  </div>
</section>
