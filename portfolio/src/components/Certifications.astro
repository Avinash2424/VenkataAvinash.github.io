---
import certs from "@/data/certs.json";

const iconMap: Record<string, string> = {
  aws: "M6.375 13.875h3.375v-4.5H6.375v4.5zM8.063 3A2.25 2.25 0 005.813 5.25v2.25h4.5V5.25A2.25 2.25 0 008.063 3z",
  gcp: "M12 2L2 7v10l10 5 10-5V7L12 2z",
  aviatrix: "M12 2L2 19h20L12 2zm0 4l6.5 11h-13L12 6z",
};
---

<section id="certifications" class="py-24">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="mb-2 font-mono text-sm text-accent-green">$ cat /etc/certs.d/*</h2>
    <h3 class="mb-12 text-3xl font-bold text-white">Certifications</h3>

    <div class="grid gap-4 sm:grid-cols-2">
      {certs.map((cert) => (
        <div class="group flex items-start gap-4 rounded-lg border border-panel-border bg-panel-light p-5 transition-all hover:border-accent-green/40">
          {/* Badge */}
          <div
            class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg"
            style={`background-color: ${cert.badgeColor}20; border: 1px solid ${cert.badgeColor}40;`}
          >
            <span class="text-lg font-bold" style={`color: ${cert.badgeColor}`}>
              {cert.shortName.split(" ")[0].charAt(0)}{cert.shortName.split(" ").length > 1 ? cert.shortName.split(" ")[1].charAt(0) : ""}
            </span>
          </div>

          <div class="flex-grow">
            <h4 class="text-sm font-semibold text-white">{cert.name}</h4>
            <p class="mt-1 text-xs text-gray-500">
              {cert.issuer}
            </p>
          </div>

          <span
            class="mt-1 flex-shrink-0 rounded-full px-2 py-0.5 text-[10px] font-semibold"
            style={`background-color: ${cert.badgeColor}20; color: ${cert.badgeColor};`}
          >
            Verified
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
