<section id="experience" class="py-24">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="mb-2 font-mono text-sm text-accent-green">$ cat experience.log</h2>
    <h3 class="mb-12 text-3xl font-bold text-white">Work Experience</h3>

    <!-- Vertical timeline -->
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 top-0 h-full w-px bg-panel-border md:left-1/2"></div>

      {experiences.map((exp, i) => (
        <div class={`relative mb-12 flex flex-col md:flex-row ${i % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"}`}>
          {/* Dot on timeline */}
          <div class="absolute left-4 top-6 z-10 h-3 w-3 -translate-x-1/2 rounded-full border-2 border-panel bg-accent-green md:left-1/2"></div>

          {/* Spacer */}
          <div class="hidden w-1/2 md:block"></div>

          {/* Content card */}
          <div class={`ml-10 w-full rounded-lg border border-panel-border bg-panel-light p-6 md:ml-0 md:w-1/2 ${i % 2 === 0 ? "md:ml-8" : "md:mr-8"}`}>
            <div class="mb-3 flex flex-wrap items-center gap-3">
              <span class={`rounded bg-panel px-2 py-0.5 font-mono text-xs text-${exp.color}`}>
                {exp.period}
              </span>
              <span class="text-xs text-gray-500">{exp.location}</span>
            </div>
            <h4 class="text-lg font-bold text-white">{exp.role}</h4>
            <p class={`mb-4 font-mono text-sm text-${exp.color}`}>{exp.company}</p>
            <ul class="space-y-2">
              {exp.bullets.map((bullet) => (
                <li class="flex gap-2 text-sm text-gray-400">
                  <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-panel-border"></span>
                  {bullet}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
