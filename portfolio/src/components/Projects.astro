---
import { fetchGitHubRepos } from "@/lib/github";
import ProjectCard from "./ProjectCard.astro";

const repos = await fetchGitHubRepos();
---

<section id="projects" class="py-24">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="mb-2 font-mono text-sm text-accent-green">$ ls ~/projects</h2>
    <h3 class="mb-4 text-3xl font-bold text-white">GitHub Projects</h3>
    <p class="mb-8 text-sm text-gray-500">
      Auto-fetched from GitHub at build time. Repos tagged <code class="text-accent-blue">#portfolio</code> appear first.
    </p>

    {repos.length > 0 ? (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {repos.map((repo) => (
          <ProjectCard repo={repo} />
        ))}
      </div>
    ) : (
      <div class="rounded-lg border border-panel-border bg-panel-light p-8 text-center">
        <p class="font-mono text-sm text-gray-500">
          ⚠ No repos fetched. Set <code>GITHUB_TOKEN</code> env var to enable GitHub API access.
        </p>
      </div>
    )}
  </div>
</section>
